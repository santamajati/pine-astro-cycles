is_venus_rx_start = array.includes(venus_start, current_bar_date)
is_mars_rx_start = array.includes(mars_start, current_bar_date)
is_jupiter_rx_start = array.includes(jupiter_start, current_bar_date)
is_saturn_rx_start = array.includes(saturn_start, current_bar_date)
is_uranus_rx_start = array.includes(uranus_start, current_bar_date)

// Retrograde Status (currently in retrograde)
in_mercury_rx = prev_retrograde(mercury_start, mercury_end)
in_venus_rx = prev_retrograde(venus_start, venus_end)
in_mars_rx = prev_retrograde(mars_start, mars_end)
in_jupiter_rx = prev_retrograde(jupiter_start, jupiter_end)
in_saturn_rx = prev_retrograde(saturn_start, saturn_end)
in_uranus_rx = prev_retrograde(uranus_start, uranus_end)

// Station Zone (±7 days from retrograde start/end)
in_mercury_station = is_in_station_zone(mercury_start, mercury_end, 7)
in_venus_station = is_in_station_zone(venus_start, venus_end, 7)
in_mars_station = is_in_station_zone(mars_start, mars_end, 7)
in_jupiter_station = is_in_station_zone(jupiter_start, jupiter_end, 7)
in_saturn_station = is_in_station_zone(saturn_start, saturn_end, 7)
in_uranus_station = is_in_station_zone(uranus_start, uranus_end, 7)

// Aspects Check
is_venus_mars_aspect = array.includes(venus_mars_aspect, current_bar_date)
is_venus_jupiter_aspect = array.includes(venus_jupiter_aspect, current_bar_date)
is_mars_jupiter_aspect = array.includes(mars_jupiter_aspect, current_bar_date)
is_mars_saturn_aspect = array.includes(mars_saturn_aspect, current_bar_date)
is_mars_uranus_aspect = array.includes(mars_uranus_aspect, current_bar_date)
is_jupiter_saturn_aspect = array.includes(jupiter_saturn_aspect, current_bar_date)
is_jupiter_uranus_aspect = array.includes(jupiter_uranus_aspect, current_bar_date)

// Ingress Check
is_jupiter_ingress = array.includes(jupiter_ingress, current_bar_date)
is_uranus_ingress = array.includes(uranus_ingress, current_bar_date)

// Moon Window ±3 days
bool is_new_moon_window = is_in_window(new_moon_dates, 3)
bool is_full_moon_window = is_in_window(full_moon_dates, 3)

// Eclipse Window ±7 days
bool is_lunar_eclipse_window = is_in_window(lunar_eclipse_dates, 5)
bool is_solar_eclipse_window = is_in_window(solar_eclipse_dates, 5)

// Aspect Window ±7 days
bool is_venus_mars_aspect_window = is_in_window(venus_mars_aspect, 7)
bool is_venus_jupiter_aspect_window = is_in_window(venus_jupiter_aspect, 7)
bool is_mars_jupiter_aspect_window = is_in_window(mars_jupiter_aspect, 7)
bool is_mars_saturn_aspect_window = is_in_window(mars_saturn_aspect, 7)
bool is_mars_uranus_aspect_window = is_in_window(mars_uranus_aspect, 7)
bool is_jupiter_saturn_aspect_window = is_in_window(jupiter_saturn_aspect, 7)
bool is_jupiter_uranus_aspect_window = is_in_window(jupiter_uranus_aspect, 7)

// ==== CURRENT STATUS CHECK END ====


// ==== FUTURE EVENTS (for next box display) ====

var table status_table = na

is_new_moon_next = false
is_full_moon_next = false
is_lunar_eclipse_next = false
is_solar_eclipse_next = false

// Tambahan: Inisialisasi Trigger Boolean untuk Future Aspect & Ingress
is_jupiter_ingress_next = false
is_uranus_ingress_next = false

is_venus_mars_aspect_next = false
is_venus_jupiter_aspect_next = false
is_mars_jupiter_aspect_next = false
is_mars_saturn_aspect_next = false
is_mars_uranus_aspect_next = false
is_jupiter_saturn_aspect_next = false
is_jupiter_uranus_aspect_next = false

var int offset_new_moon = na
var int offset_full_moon = na
var int offset_lunar_eclipse = na
var int offset_solar_eclipse = na

// Tambahan: Inisialisasi Persistent Variable Offset Proyeksi untuk Aspect & Ingress
var int offset_jupiter_ingress = na
var int offset_uranus_ingress = na

var int offset_venus_mars_aspect = na
var int offset_venus_jupiter_aspect = na
var int offset_mars_jupiter_aspect = na
var int offset_mars_saturn_aspect = na
var int offset_mars_uranus_aspect = na
var int offset_jupiter_saturn_aspect = na
var int offset_jupiter_uranus_aspect = na

if barstate.islast
    int bar_duration = int(ta.change(time))
    if timeframe.isminutes
        bar_duration := timeframe.multiplier * 60 * 1000
    else if timeframe.isdaily
        bar_duration := 86400000
    else if timeframe.isweekly
        bar_duration := 604800000
        
    [offset_nm, trigger_nm] = calc_future(new_moon_dates, bar_duration)
    offset_new_moon := offset_nm
    is_new_moon_next := trigger_nm

    [offset_fm, trigger_fm] = calc_future(full_moon_dates, bar_duration)
    offset_full_moon := offset_fm
    is_full_moon_next := trigger_fm

    [offset_le, trigger_le] = calc_future(lunar_eclipse_dates, bar_duration)
    offset_lunar_eclipse := offset_le
    is_lunar_eclipse_next := trigger_le

    [offset_se, trigger_se] = calc_future(solar_eclipse_dates, bar_duration)
    offset_solar_eclipse := offset_se
    is_solar_eclipse_next := trigger_se

    // Tambahan: Kalkulasi Offset Masa Depan untuk Ingress
    [offset_ji, trigger_ji] = calc_future(jupiter_ingress, bar_duration)
    offset_jupiter_ingress := offset_ji
    is_jupiter_ingress_next := trigger_ji

    [offset_ui, trigger_ui] = calc_future(uranus_ingress, bar_duration)
    offset_uranus_ingress := offset_ui
    is_uranus_ingress_next := trigger_ui

    // Tambahan: Kalkulasi Offset Masa Depan untuk Aspects
    [offset_vm, trigger_vm] = calc_future(venus_mars_aspect, bar_duration)
    offset_venus_mars_aspect := offset_vm
    is_venus_mars_aspect_next := trigger_vm

    [offset_vj, trigger_vj] = calc_future(venus_jupiter_aspect, bar_duration)
    offset_venus_jupiter_aspect := offset_vj
    is_venus_jupiter_aspect_next := trigger_vj

    [offset_mj, trigger_mj] = calc_future(mars_jupiter_aspect, bar_duration)
    offset_mars_jupiter_aspect := offset_mj
    is_mars_jupiter_aspect_next := trigger_mj

    [offset_ms, trigger_ms] = calc_future(mars_saturn_aspect, bar_duration)
    offset_mars_saturn_aspect := offset_ms
    is_mars_saturn_aspect_next := trigger_ms

    [offset_mu, trigger_mu] = calc_future(mars_uranus_aspect, bar_duration)
    offset_mars_uranus_aspect := offset_mu
    is_mars_uranus_aspect_next := trigger_mu

    [offset_js, trigger_js] = calc_future(jupiter_saturn_aspect, bar_duration)
    offset_jupiter_saturn_aspect := offset_js
    is_jupiter_saturn_aspect_next := trigger_js

    [offset_ju, trigger_ju] = calc_future(jupiter_uranus_aspect, bar_duration)
    offset_jupiter_uranus_aspect := offset_ju
    is_jupiter_uranus_aspect_next := trigger_ju

    // Draw retrograde boxes
    next_retrograde_box(mercury_start, mercury_end, bar_duration, "MER RX", color.rgb(136, 136, 136), 0)
    next_retrograde_box(venus_start, venus_end, bar_duration, "VEN RX", color.rgb(227, 218, 201), 1)
    next_retrograde_box(mars_start, mars_end, bar_duration, "MAR RX", color.rgb(193, 89, 41), 2)
    next_retrograde_box(jupiter_start, jupiter_end, bar_duration, "JUP RX", color.rgb(181, 140, 98), 3)
    next_retrograde_box(saturn_start, saturn_end, bar_duration, "SAT RX", color.rgb(226, 193, 132), 4)
    next_retrograde_box(uranus_start, uranus_end, bar_duration, "URA RX", color.rgb(175, 227, 224), 5)


    info_text = "\n  CURRENT ASTRO STATUS  \n\n"
    
    if is_new_moon_window
        info_text += "  New Moon Window (±3)  \n"
    if is_full_moon_window
        info_text += "  Full Moon Window (±3)  \n"
    if is_lunar_eclipse_window
        info_text += "  Lunar Eclipse Window (±5)  \n"
    if is_solar_eclipse_window
        info_text += "  Solar Eclipse Window (±5)  \n"
        
    if in_mercury_station
        info_text += "  Mercury Station  \n"
    if in_venus_station
        info_text += "  Venus Station  \n"
    if in_mars_station
        info_text += "  Mars Station  \n"
    if in_jupiter_station
        info_text += "  Jupiter Station  \n"
    if in_saturn_station
        info_text += "  Saturn Station  \n"
    if in_uranus_station
        info_text += "  Uranus Station  \n"
        
    if in_mercury_rx
        info_text += "  Mercury Retrograde  \n"
    if in_venus_rx
        info_text += "  Venus Retrograde  \n"
    if in_mars_rx
        info_text += "  Mars Retrograde  \n"
        
    if is_venus_mars_aspect
        info_text += "  Venus-Mars Aspect  \n"
    if is_venus_jupiter_aspect
        info_text += "  Venus-Jupiter Aspect  \n"
    if is_mars_uranus_aspect
        info_text += "  Mars-Uranus Aspect  \n"
    if is_mars_saturn_aspect
        info_text += "  Mars-Saturn Aspect  \n"
    if is_jupiter_saturn_aspect
        info_text += "  Jupiter-Saturn Aspect  \n"
    if is_jupiter_uranus_aspect
        info_text += "  Jupiter-Uranus Aspect  \n"

    if is_venus_mars_aspect_window
        info_text += "  Venus-Mars Aspect Window (±7)  \n"
    if is_venus_jupiter_aspect_window
        info_text += "  Venus-Jupiter Aspect Window (±7)  \n"
    if is_mars_uranus_aspect_window
        info_text += "  Mars-Uranus Aspect Window (±7)  \n"
    if is_mars_saturn_aspect_window
        info_text += "  Mars-Saturn Aspect Window (±7)  \n"
    if is_jupiter_saturn_aspect_window
        info_text += "  Jupiter-Saturn Aspect Window (±7)  \n"
    if is_jupiter_uranus_aspect_window
        info_text += "  Jupiter-Uranus Aspect Window (±7)  \n"
    
    if na(status_table)
        status_table := table.new(position=position.top_right,
                                   rows=1, columns=1, 
                                   bgcolor=color.new(color.black, 30),
                                   border_color=color.gray,
                                   border_width=2)
        table.cell(status_table, 0, 0, info_text, 
                  text_color=color.white, 
                  text_size=size.small,
                  bgcolor=color.new(color.black, 50),
                  text_halign=text.align_left)
    else
        table.cell(status_table, 0, 0, info_text, 
                  text_color=color.white, 
                  text_size=size.small,
                  bgcolor=color.new(color.black, 50),
                  text_halign=text.align_left)
                  
// ==== FUTURE EVENTS END ====



// ==== VISUAL DISPLAYS ====

// MOON PHASES
plotshape(is_new_moon_prev, title="NM-Exact", style=shape.labelup, location=location.bottom, color=color.new(color.gray, 80), text="NM", textcolor=color.white, size=size.small)
plotshape(is_new_moon_next, title="NM-Next", style=shape.labelup, location=location.bottom, color=color.new(color.gray, 80), text="NM", textcolor=color.white, size=size.small, offset=offset_new_moon)

plotshape(is_full_moon_prev, title="FM-Exact", style=shape.labelup, location=location.bottom, color=color.new(color.orange, 80), text="FM", textcolor=color.white, size=size.small)
plotshape(is_full_moon_next, title="FM-Next", style=shape.labelup, location=location.bottom, color=color.new(color.orange, 80), text="FM", textcolor=color.white, size=size.small, offset=offset_full_moon)

// ECLIPSES
plotshape(is_lunar_eclipse_prev, title="LE-Exact", style=shape.labeldown, location=location.top, color=color.new(color.red, 80), text="LE", textcolor=color.white, size=size.small)
plotshape(is_lunar_eclipse_next, title="LE-Next", style=shape.labeldown, location=location.top, color=color.new(color.red, 80), text="LE", textcolor=color.white, size=size.small, offset=offset_lunar_eclipse)

plotshape(is_solar_eclipse_prev, title="SE-Exact", style=shape.labeldown, location=location.top, color=color.new(color.orange, 80), text="SE", textcolor=color.white, size=size.small)
plotshape(is_solar_eclipse_next, title="SE-Next", style=shape.labeldown, location=location.top, color=color.new(color.orange, 80), text="SE", textcolor=color.white, size=size.small, offset=offset_solar_eclipse)

// RETROGRADE START SIGNALS
plotshape(is_mercury_rx_start, title="MER RX START", style=shape.labeldown, location=location.top, color=color.new(color.rgb(136, 136, 136), 80), text="MER RX", textcolor=color.white, size=size.small)
plotshape(is_venus_rx_start, title="VEN RX START", style=shape.labeldown, location=location.top, color=color.new(color.rgb(227, 218, 201), 80), text="VEN RX", textcolor=color.white, size=size.small)
plotshape(is_mars_rx_start, title="MAR RX START", style=shape.labeldown, location=location.top, color=color.new(color.rgb(193, 89, 41), 80), text="MAR RX", textcolor=color.white, size=size.small)
plotshape(is_jupiter_rx_start, title="JUP RX START", style=shape.labeldown, location=location.top, color=color.new(color.rgb(181, 140, 98), 80), text="JUP RX", textcolor=color.white, size=size.small)
plotshape(is_saturn_rx_start, title="SAT RX START", style=shape.labeldown, location=location.top, color=color.new(color.rgb(226, 193, 132), 80), text="SAT RX", textcolor=color.white, size=size.small)
plotshape(is_uranus_rx_start, title="URA RX START", style=shape.labeldown, location=location.top, color=color.new(color.rgb(175, 227, 224), 80), text="URA RX", textcolor=color.white, size=size.small)

// LIGHTER BACKGROUND FOR JUST RETROGRADE (no station)
bgcolor((in_mercury_rx and not in_mercury_station) ? color.new(color.rgb(136, 136, 136), 90) : na, title="MER RX")
bgcolor((in_venus_rx and not in_venus_station) ? color.new(color.rgb(227, 218, 201), 90) : na, title="VEN RX")
bgcolor((in_mars_rx and not in_mars_station) ? color.new(color.rgb(193, 89, 41), 90) : na, title="MAR RX")
bgcolor((in_jupiter_rx and not in_jupiter_station) ? color.new(color.rgb(181, 140, 98), 90) : na, title="JUP RX")
bgcolor((in_saturn_rx and not in_saturn_station) ? color.new(color.rgb(226, 193, 132), 90) : na, title="SAT RX")
bgcolor((in_uranus_rx and not in_uranus_station) ? color.new(color.rgb(175, 227, 224), 90) : na, title="URA RX")

bgcolor(in_mercury_rx ? color.new(color.rgb(136, 136, 136), 90) : na, title="MER RX")
bgcolor(in_venus_rx ? color.new(color.rgb(227, 218, 201), 90) : na, title="VEN RX")
bgcolor(in_mars_rx ? color.new(color.rgb(193, 89, 41), 90) : na, title="MAR RX")
bgcolor(in_jupiter_rx ? color.new(color.rgb(181, 140, 98), 90) : na, title="JUP RX")
bgcolor(in_saturn_rx ? color.new(color.rgb(226, 193, 132), 90) : na, title="SAT RX")
bgcolor(in_uranus_rx ? color.new(color.rgb(175, 227, 224), 90) : na, title="URA RX")

// ASPECTS & INGRESS (EXACT / HISTORICAL DATA)
plotshape(is_jupiter_ingress, title="JUPITER INGRESS", style=shape.labeldown, location=location.top, color=color.new(color.blue, 80), text="JUP IN", textcolor=color.white, size=size.small)
plotshape(is_uranus_ingress, title="URANUS INGRESS", style=shape.labeldown, location=location.top, color=color.new(color.aqua, 80), text="URA IN", textcolor=color.white, size=size.small)

plotshape(is_venus_mars_aspect, title="VEN-MAR ASPECT", style=shape.labeldown, location=location.top, color=color.new(color.rgb(255, 105, 180), 80), text="VEN-MAR", textcolor=color.white, size=size.small)
plotshape(is_venus_jupiter_aspect, title="VEN-JUP ASPECT", style=shape.labeldown, location=location.top, color=color.new(color.rgb(255, 215, 0), 80), text="VEN-JUP", textcolor=color.white, size=size.small)
plotshape(is_mars_jupiter_aspect, title="MAR-JUP ASPECT", style=shape.labeldown, location=location.top, color=color.new(color.rgb(0, 255, 127), 80), text="MAR-JUP", textcolor=color.white, size=size.small)
plotshape(is_mars_uranus_aspect, title="MAR-URANUS ASPECT", style=shape.labeldown, location=location.top, color=color.new(color.rgb(255, 140, 0), 80), text="MAR-URA", textcolor=color.white, size=size.small) // Fixed Text Bug
plotshape(is_mars_saturn_aspect, title="MAR-SAT ASPECT", style=shape.labeldown, location=location.top, color=color.new(color.red, 80), text="MAR-SAT", textcolor=color.white, size=size.small)     // Fixed Text Bug
plotshape(is_jupiter_saturn_aspect, title="JUP-SAT ASPECT", style=shape.labeldown, location=location.top, color=color.new(color.purple, 80), text="JUP-SAT", textcolor=color.white, size=size.small)
plotshape(is_jupiter_uranus_aspect, title="JUP-URA ASPECT", style=shape.labeldown, location=location.top, color=color.new(color.lime, 80), text="JUP-URA", textcolor=color.white, size=size.small)


// ==== TAMBAHAN: PROYEKSI/LABEL MASA DEPAN (NEXT / PROJECTION DATA) ====

// INGRESS NEXT
plotshape(is_jupiter_ingress_next, title="JUPITER INGRESS-Next", style=shape.labeldown, location=location.top, color=color.new(color.blue, 80), text="JUP IN", textcolor=color.white, size=size.small, offset=offset_jupiter_ingress)
plotshape(is_uranus_ingress_next, title="URANUS INGRESS-Next", style=shape.labeldown, location=location.top, color=color.new(color.aqua, 80), text="URA IN", textcolor=color.white, size=size.small, offset=offset_uranus_ingress)

// ASPECTS NEXT
plotshape(is_venus_mars_aspect_next, title="VEN-MAR-Next", style=shape.labeldown, location=location.top, color=color.new(color.rgb(255, 105, 180), 80), text="VEN-MAR", textcolor=color.white, size=size.small, offset=offset_venus_mars_aspect)
plotshape(is_venus_jupiter_aspect_next, title="VEN-JUP-Next", style=shape.labeldown, location=location.top, color=color.new(color.rgb(255, 215, 0), 80), text="VEN-JUP", textcolor=color.white, size=size.small, offset=offset_venus_jupiter_aspect)
plotshape(is_mars_jupiter_aspect_next, title="MAR-JUP-Next", style=shape.labeldown, location=location.top, color=color.new(color.rgb(0, 255, 127), 80), text="MAR-JUP", textcolor=color.white, size=size.small, offset=offset_mars_jupiter_aspect)
plotshape(is_mars_uranus_aspect_next, title="MAR-URA-Next", style=shape.labeldown, location=location.top, color=color.new(color.rgb(255, 140, 0), 80), text="MAR-URA", textcolor=color.white, size=size.small, offset=offset_mars_uranus_aspect)
plotshape(is_mars_saturn_aspect_next, title="MAR-SAT-Next", style=shape.labeldown, location=location.top, color=color.new(color.red, 80), text="MAR-SAT", textcolor=color.white, size=size.small, offset=offset_mars_saturn_aspect)
plotshape(is_jupiter_saturn_aspect_next, title="JUP-SAT-Next", style=shape.labeldown, location=location.top, color=color.new(color.purple, 80), text="JUP-SAT", textcolor=color.white, size=size.small, offset=offset_jupiter_saturn_aspect)
plotshape(is_jupiter_uranus_aspect_next, title="JUP-URA-Next", style=shape.labeldown, location=location.top, color=color.new(color.lime, 80), text="JUP-URA", textcolor=color.white, size=size.small, offset=offset_jupiter_uranus_aspect)

// ==== VISUAL DISPLAYS END ====
