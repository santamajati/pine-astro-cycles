//@version=5
indicator(title="Astro Cycles - Crypto", overlay=true, max_boxes_count=500, max_labels_count=500, max_lines_count=500)


// ==== HELPER FUNCTIONS ====

calc_future(string[] array_date, int bar_duration) =>
    int result_offset = na
    bool is_active = false
    
    if array.size(array_date) > 0
        for i = 0 to array.size(array_date) - 1
            target_str = array.get(array_date, i)
            
            int thn = int(str.tonumber(str.substring(target_str, 0, 4)))
            int bln = int(str.tonumber(str.substring(target_str, 5, 7)))
            int tgl = int(str.tonumber(str.substring(target_str, 8, 10)))
            int target_time = timestamp(thn, bln, tgl, 0, 0, 0)
            
            if target_time > time_close
                result_offset := math.round((target_time - time) / bar_duration)
                is_active := true
                break
                
    [result_offset, is_active]

prev_retrograde(string[] start_array, string[] end_array) =>
    bool in_range = false
    if array.size(start_array) > 0
        for i = 0 to array.size(start_array) - 1
            str_s = array.get(start_array, i)
            int s_thn = int(str.tonumber(str.substring(str_s, 0, 4)))
            int s_bln = int(str.tonumber(str.substring(str_s, 5, 7)))
            int s_tgl = int(str.tonumber(str.substring(str_s, 8, 10)))
            int start_time = timestamp(s_thn, s_bln, s_tgl, 0, 0, 0)
            
            str_e = array.get(end_array, i)
            int e_thn = int(str.tonumber(str.substring(str_e, 0, 4)))
            int e_bln = int(str.tonumber(str.substring(str_e, 5, 7)))
            int e_tgl = int(str.tonumber(str.substring(str_e, 8, 10)))
            int end_time = timestamp(e_thn, e_bln, e_tgl, 23, 59, 59)
            
            if time >= start_time and time <= end_time
                in_range := true
                break
    in_range

is_in_station_zone(string[] start_array, string[] end_array, int buffer_days) =>
    bool in_station = false
    if array.size(start_array) > 0
        for i = 0 to array.size(start_array) - 1
            str_s = array.get(start_array, i)
            int s_thn = int(str.tonumber(str.substring(str_s, 0, 4)))
            int s_bln = int(str.tonumber(str.substring(str_s, 5, 7)))
            int s_tgl = int(str.tonumber(str.substring(str_s, 8, 10)))
            int start_time = timestamp(s_thn, s_bln, s_tgl, 0, 0, 0)
            
            str_e = array.get(end_array, i)
            int e_thn = int(str.tonumber(str.substring(str_e, 0, 4)))
            int e_bln = int(str.tonumber(str.substring(str_e, 5, 7)))
            int e_tgl = int(str.tonumber(str.substring(str_e, 8, 10)))
            int end_time = timestamp(e_thn, e_bln, e_tgl, 23, 59, 59)
            
            int station_start = start_time - (buffer_days * 86400000)
            int station_end = end_time + (buffer_days * 86400000)
            
            if time >= station_start and time <= station_end
                in_station := true
                break
    in_station

is_in_window(string[] date_array, int window) =>
    bool in_window = false
    int array_size = array.size(date_array)
    
    if array_size > 0
        for i = 0 to array_size - 1
            string str_date = array.get(date_array, i)
            int y = int(str.tonumber(str.substring(str_date, 0, 4)))
            int m = int(str.tonumber(str.substring(str_date, 5, 7)))
            int d = int(str.tonumber(str.substring(str_date, 8, 10)))
            int target_time = timestamp(y, m, d, 0, 0, 0)
            
            if math.abs(time - target_time) <= window * 86400000
                in_window := true
                break
    
    in_window

next_retrograde_box(string[] start_array, string[] end_array, int bar_duration, string planet, color warna_planet, int level) =>
    if array.size(start_array) > 0
        for i = 0 to array.size(start_array) - 1
            str_s = array.get(start_array, i)
            int s_thn = int(str.tonumber(str.substring(str_s, 0, 4)))
            int s_bln = int(str.tonumber(str.substring(str_s, 5, 7)))
            int s_tgl = int(str.tonumber(str.substring(str_s, 8, 10)))
            int start_time = timestamp(s_thn, s_bln, s_tgl, 0, 0, 0)
            
            str_e = array.get(end_array, i)
            int e_thn = int(str.tonumber(str.substring(str_e, 0, 4)))
            int e_bln = int(str.tonumber(str.substring(str_e, 5, 7)))
            int e_tgl = int(str.tonumber(str.substring(str_e, 8, 10)))
            int end_time = timestamp(e_thn, e_bln, e_tgl, 23, 59, 59)
            
            if start_time > time_close
                int offset_start = math.round((start_time - time) / bar_duration)
                int offset_end   = math.round((end_time - time) / bar_duration)
                
                float batas_atas  = ta.highest(high, 500) * 1.3 - (level * ta.highest(high, 500) * 0.05)
                float batas_bawah = ta.lowest(low, 500) * 0.7 - (level * ta.lowest(low, 500) * 0.05)
                
                box.new(left=bar_index + offset_start, top=batas_atas,
                         right=bar_index + offset_end, bottom=batas_bawah,
                         bgcolor=color.new(warna_planet, 92), border_color=warna_planet,
                         border_style=line.style_dashed, extend=extend.none)
                        
                label.new(x=bar_index + offset_start, y=batas_atas, text=planet, 
                         yloc=yloc.price, color=color.new(color.black, 70), 
                         textcolor=warna_planet, style=label.style_label_down, size=size.small)
                break

// ==== HELPER FUNCTIONS END ====



