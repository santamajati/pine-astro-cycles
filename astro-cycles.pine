// ==== CURRENT STATUS CHECK ====

string current_bar_date = str.format("{0,date,yyyy-MM-dd}", time)

// Moon Check
is_new_moon_prev = array.includes(new_moon_dates, current_bar_date)
is_full_moon_prev = array.includes(full_moon_dates, current_bar_date)

// Eclipse Check
is_lunar_eclipse_prev = array.includes(lunar_eclipse_dates, current_bar_date)
is_solar_eclipse_prev = array.includes(solar_eclipse_dates, current_bar_date)

// Retrograde Start Check
